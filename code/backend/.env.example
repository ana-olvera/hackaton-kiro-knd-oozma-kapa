# ============================================
# Configuración del servidor
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Base de datos
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=michi_godin
DB_USER=tu_usuario
DB_PASSWORD=tu_password

# ============================================
# JWT (para autenticación de certificados)
# ============================================
JWT_SECRET=cambia_este_secreto_por_uno_seguro
JWT_EXPIRES_IN=7d

# ============================================
# Aplicación
# ============================================
FRONTEND_URL=http://localhost:4200
CERTIFICATES_BASE_URL=https://michi-godin.app/verify
